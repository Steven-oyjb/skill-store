# Skill Store 环境变量配置
# 复制此文件为 .env 并填入实际值

# ========== 应用配置 ==========
NODE_ENV=production
PORT=3001

# ========== 飞书配置 ==========
# 飞书应用 ID（在开发者后台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxx

# 飞书应用密钥（在开发者后台获取）
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 OAuth 回调地址
FEISHU_REDIRECT_URI=http://localhost:3001/api/auth/callback

# 飞书机器人 Open ID（可选，用于消息推送）
FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxx

# ========== AI 配置 ==========
# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# AI 模型（可选，默认 claude-3-5-sonnet-20241022）
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ========== 前端配置 ==========
# 前端端口
FRONTEND_PORT=3000

# 后端端口
BACKEND_PORT=3001

# ========== 可选配置 ==========
# 管理员页面地址（用于消息通知跳转）
ADMIN_URL=http://localhost:3000/admin
